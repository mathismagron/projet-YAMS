CREATE USER SA PASSWORD DIGEST 'd41d8cd98f00b204e9800998ecf8427e'
ALTER USER SA SET LOCAL TRUE
CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE MEMORY TABLE PUBLIC.ACHIEVEMENT(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY)
ALTER TABLE PUBLIC.ACHIEVEMENT ALTER COLUMN ID RESTART WITH 1
CREATE MEMORY TABLE PUBLIC.FRIENDSHIP(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY)
ALTER TABLE PUBLIC.FRIENDSHIP ALTER COLUMN ID RESTART WITH 1
CREATE MEMORY TABLE PUBLIC.GAME(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,CURRENT_PLAYER_INDEX INTEGER NOT NULL,ROLL_COUNT INTEGER NOT NULL,STATUS VARCHAR(255),HOST_ID BIGINT,IS_PRIVATE BOOLEAN,JOIN_CODE VARCHAR(255))
ALTER TABLE PUBLIC.GAME ALTER COLUMN ID RESTART WITH 7
CREATE MEMORY TABLE PUBLIC.GAME_DICE(GAME_ID BIGINT NOT NULL,DICE INTEGER,CONSTRAINT FKSWPYJFII0UMYH3TGWS5R5F04K FOREIGN KEY(GAME_ID) REFERENCES PUBLIC.GAME(ID))
CREATE MEMORY TABLE PUBLIC.GAME_SCORECARDS(GAME_ID BIGINT NOT NULL,SCORECARDS_ID BIGINT NOT NULL,CONSTRAINT UK_4WJPEOEP594QBRM3WKAX9ELCN UNIQUE(SCORECARDS_ID),CONSTRAINT FKKFNATY7N3QJP74IJ2S9MOTE6A FOREIGN KEY(GAME_ID) REFERENCES PUBLIC.GAME(ID))
CREATE MEMORY TABLE PUBLIC.INVITATION(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY)
ALTER TABLE PUBLIC.INVITATION ALTER COLUMN ID RESTART WITH 1
CREATE MEMORY TABLE PUBLIC.MESSAGE(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,AUTHOR_NAME VARCHAR(255),CONTENT VARCHAR(255),GAME_ID BIGINT,TIMESTAMP TIMESTAMP)
ALTER TABLE PUBLIC.MESSAGE ALTER COLUMN ID RESTART WITH 7
CREATE MEMORY TABLE PUBLIC.PLAYER(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY)
ALTER TABLE PUBLIC.PLAYER ALTER COLUMN ID RESTART WITH 1
CREATE MEMORY TABLE PUBLIC.SCORECARD(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,TOTAL_SCORE INTEGER NOT NULL,PLAYER_ID BIGINT)
ALTER TABLE PUBLIC.SCORECARD ALTER COLUMN ID RESTART WITH 12
CREATE MEMORY TABLE PUBLIC.SCORECARD_SCORES(SCORECARD_ID BIGINT NOT NULL,SCORE INTEGER,CATEGORY VARCHAR(255) NOT NULL,PRIMARY KEY(SCORECARD_ID,CATEGORY),CONSTRAINT FKMV441GS2L8596P17BF3G5GBCG FOREIGN KEY(SCORECARD_ID) REFERENCES PUBLIC.SCORECARD(ID))
CREATE MEMORY TABLE PUBLIC.TURN(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY)
ALTER TABLE PUBLIC.TURN ALTER COLUMN ID RESTART WITH 1
CREATE MEMORY TABLE PUBLIC.USERS(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,PASSWORD VARCHAR(255) NOT NULL,USERNAME VARCHAR(255) NOT NULL,CONSTRAINT UK_R43AF9AP4EDM43MMTQ01ODDJ6 UNIQUE(USERNAME))
ALTER TABLE PUBLIC.USERS ALTER COLUMN ID RESTART WITH 10
ALTER TABLE PUBLIC.GAME ADD CONSTRAINT FK2AV8N5S5UAY0TE77NP99EOT44 FOREIGN KEY(HOST_ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.GAME_SCORECARDS ADD CONSTRAINT FKRUB2LMK9KH6VT3LYNL0BW8SGW FOREIGN KEY(SCORECARDS_ID) REFERENCES PUBLIC.SCORECARD(ID)
ALTER TABLE PUBLIC.SCORECARD ADD CONSTRAINT FKS0GUDC69HSRKK1I9S0LLGHFWI FOREIGN KEY(PLAYER_ID) REFERENCES PUBLIC.USERS(ID)
